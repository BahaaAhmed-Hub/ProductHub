VITE_SUPABASE_ANON_KEY=your-anon-key

# Lens analytics module (PostHog Cloud) — wired in M6
VITE_POSTHOG_HOST=https://us.posthog.com
VITE_POSTHOG_API_KEY=phx_xxx
VITE_POSTHOG_PROJECT_ID=1

# Server-side only (Edge Functions / cron) — NEVER prefixed VITE_
